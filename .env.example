NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TU_LLAVE_PUBLICA

# --- Modulo Clinica (opcionales; la app degrada elegantemente sin ellos) ---

# URL publica del sitio (para el callback de Google OAuth y enlaces)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Service role de Supabase (solo servidor; requerido para Google Calendar)
SUPABASE_SECRET_KEY=

# Google Calendar (crear credenciales OAuth en Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resumenes de sesion con IA (Claude)
ANTHROPIC_API_KEY=
# Modelo opcional (default: claude-sonnet-5)
ANTHROPIC_MODEL=
